{
  "private": true,
  "name": "once-ui-monorepo",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build --filter=@once-ui-system/docs...",
    "format": "pnpm -r --if-present run format && pnpm -r --if-present run biome-write"
  },
  "engines": {
    "node": "20.x"
  },
  "packageManager": "pnpm@10.14.0",
  "devDependencies": {
    "turbo": "^2.5.6"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.5",
      "@types/react-dom": "19.2.3"
    }
  }
}
